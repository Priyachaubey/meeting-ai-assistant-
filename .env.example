APP_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000
# Comma-separated extra CORS origins (e.g. a staging domain). localhost:3000/3001 are already
# allowed automatically in development — see core/config.py's cors_allowed_origins.
CORS_ALLOWED_ORIGINS_EXTRA=
DATABASE_URL=postgresql+psycopg://convopilot:convopilot@localhost:5432/convopilot
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
JWT_SECRET=change-me-with-32-byte-secret
ENCRYPTION_KEY=change-me-32-byte-base64-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# As of the self-hosted-models merge, apps/api tries the self-hosted ai-server first (no
# API key needed — just needs apps/ai-server running and reachable at AI_SERVER_URL below),
# falling back to openai/claude automatically if ai-server is unreachable. Set back to
# "openai" or "claude" here to go back to cloud-first instead.
LLM_PROVIDER=ai-server
AI_SERVER_URL=http://localhost:8001
# Which provider to use for RAG/knowledge base embeddings.
# "ai-server" uses sentence-transformers (384-dim, no API key needed).
# "openai"    uses text-embedding-3-small (1536-dim, requires OPENAI_API_KEY).
# IMPORTANT: changing this after you've already indexed documents requires re-ingesting all
# content — Qdrant collections are dimensionally locked at creation time. On a fresh deploy
# (empty Qdrant) this can be changed freely.
EMBEDDING_PROVIDER=ai-server
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
# As of the self-hosted-models merge, apps/api tries the self-hosted ai-server first for
# transcription too (utterance-segmented via VAD, see ai_server_provider.py) — falls back
# to deepgram/assemblyai automatically if ai-server is unreachable. Set back to "deepgram"
# or "assemblyai" here to go back to cloud-first.
SPEECH_PROVIDER=ai-server
ASSEMBLYAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
SENTRY_DSN=
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_ENDPOINT_URL=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# Added from Phase 5 merge — AI Server (self-hosted ML) + Meeting Server
# ═══════════════════════════════════════════════════════════════════════════
# NOTE: AI_LLM_PROVIDER / AI_SPEECH_PROVIDER are deliberately named
# differently from LLM_PROVIDER / SPEECH_PROVIDER above. Those existing
# vars already mean "which paid cloud provider apps/api should call"
# (openai/anthropic, deepgram/assemblyai). The ai-server container reuses
# the *names* LLM_PROVIDER/SPEECH_PROVIDER internally for a different
# thing ("ml" vs "ollama" engine mode) — if both services shared one .env
# with the same variable name, whichever value wins would silently break
# the other service. These prefixed vars keep them independent.
AI_LLM_PROVIDER=ml
AI_SPEECH_PROVIDER=ml

AI_SERVER_PORT=8001
USE_ML_MODELS=true
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
WHISPER_MODEL_SIZE=large-v3-turbo
TRANSLATION_PROVIDER=ml
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
EMBEDDING_PROVIDER=ml
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VISION_PROVIDER=ml
OCR_PROVIDER=ml
DIARIZATION_ENABLED=true
# Required to download pyannote speaker-diarization models — accept the
# license at huggingface.co/pyannote/speaker-diarization-3.1 first.
HUGGINGFACE_TOKEN=

# Ollama mode (alternative to direct transformers loading — lighter, but
# needs the separate `ollama` container/profile running)
OLLAMA_MODEL=qwen2.5:7b-instruct

# Where downloaded models are cached (mounted as a Docker volume by default)
MODEL_DIR=./model_cache

# ── Frontend build-time URLs ─────────────────────────────────────────────
# CRITICAL: these are read by `next build` (a Docker BUILD step, via the
# `web` service's `build.args` in docker-compose.yml) — NOT by the running
# container. Changing these in this file and just restarting the `web`
# container does NOTHING; you must rebuild it: `docker compose build web`.
# In production, set these to your real public URLs BEFORE building —
# leaving them as localhost defaults bakes "localhost" into the production
# JS bundle every visitor's browser downloads, which is exactly what was
# causing "Could not reach the API at http://localhost:8002/..." errors.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MEETING_SERVER_URL=http://localhost:8002
NEXT_PUBLIC_MEETING_WS_URL=ws://localhost:8002
# Production example (replace with your real domains):
# NEXT_PUBLIC_API_URL=https://api.meeting.microtechnique.in
# NEXT_PUBLIC_WS_URL=wss://api.meeting.microtechnique.in
# NEXT_PUBLIC_MEETING_SERVER_URL=https://rooms.meeting.microtechnique.in
# NEXT_PUBLIC_MEETING_WS_URL=wss://rooms.meeting.microtechnique.in

# Optional TURN server for the meeting room's real WebRTC (apps/web/src/hooks/
# use-webrtc-mesh.ts). Public STUN (Google's) is always used and needs no config — but STUN
# alone cannot connect two participants who are both behind symmetric NAT or a restrictive
# corporate firewall; only a real TURN server (relays media when a direct path can't be
# found) fixes that. Leave unset to run STUN-only (fine for most home/office networks during
# testing); set these for reliable connections in production. Self-host coturn, or use a
# managed TURN provider — either way this is real infrastructure to provision and test, not
# something that can be defaulted into working.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
